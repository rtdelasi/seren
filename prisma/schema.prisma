datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  password        String?          // Required for Credentials Provider authorization
  role            UserRole         @default(CLIENT)
  accounts        Account[]
  sessions        Session[]
  journalEntries  JournalEntry[]
  therapySessions TherapySession[]
  emailReminders  Boolean          @default(true)
  emailMessages   Boolean          @default(true)
  emailWelcome    Boolean          @default(true)
  crisisAlerts    CrisisAlert[]
  savedResources  SavedResource[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Therapist {
  id               String   @id @default(cuid())
  name             String
  image            String?
  email            String?  @unique
  specialties      String[]
  languages        String[]
  acceptingClients Boolean  @default(true)
  avgRating        Float    @default(5.0)
  pricePerSession  Int
  bio              String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  therapySessions  TherapySession[]
}

model MatchRequest {
  id              String   @id @default(cuid())
  issue           String
  goals           String
  preferredGender String?
  language        String
  createdAt       DateTime @default(now())
}

model JournalEntry {
  id         String   @id @default(cuid())
  userId     String
  content    String   @db.Text
  sentiment  Float    // sentiment score from -1.0 to 1.0
  reflection String   @db.Text
  suggestion String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TherapySession {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  duration    Int      // duration in minutes
  status      String   // e.g. "SCHEDULED", "ACTIVE", "COMPLETED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  note        TherapyNote?
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  senderType String   // "USER" or "THERAPIST"
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailJob {
  id          String   @id @default(cuid())
  to          String
  subject     String
  html        String   @db.Text
  status      String   // "PENDING", "SENT", "FAILED"
  attempts    Int      @default(0)
  lastError   String?  @db.Text
  scheduledAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CrisisAlert {
  id          String   @id @default(cuid())
  userId      String
  riskLevel   String   // "none" | "low" | "medium" | "high"
  reason      String   @db.Text
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TherapyNote {
  id        String   @id @default(cuid())
  sessionId String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SavedResource {
  id         String   @id @default(cuid())
  userId     String
  resourceId String   // ID referencing the JSON resource
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

enum UserRole {
  CLIENT
  THERAPIST
}
